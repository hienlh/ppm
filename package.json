{
  "name": "ppm",
  "version": "0.1.0",
  "description": "Personal Project Manager — mobile-first web IDE running as CLI daemon",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "ppm": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts start",
    "dev:web": "vite dev",
    "build:web": "vite build",
    "build": "bun run build:web && bun build --compile src/index.ts --outfile=dist/ppm",
    "typecheck": "tsc --noEmit",
    "start": "bun run src/index.ts start",
    "test": "bun test"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@uiw/react-codemirror": "^4.25.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "commander": "^14.0.3",
    "diff2html": "^3.4.56",
    "hono": "^4.12.8",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.2",
    "simple-git": "^3.33.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  }
}
