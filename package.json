{
  "name": "@hienlh/ppm",
  "version": "0.13.15",
  "description": "Personal Project Manager — mobile-first web IDE with AI assistance",
  "author": "hienlh",
  "license": "MIT",
  "module": "src/index.ts",
  "type": "module",
  "workspaces": ["packages/*"],
  "bin": {
    "ppm": "src/index.ts"
  },
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun run --hot src/server/index.ts __serve__ 8081 0.0.0.0 '' dev",
    "dev:web": "bun run vite --config vite.config.ts",
    "build:web": "bun run vite build --config vite.config.ts",
    "build": "bun run build:web && bun build src/index.ts --compile --outfile dist/ppm",
    "start": "bun run src/index.ts start",
    "typecheck": "bunx tsc --noEmit",
    "generate:bot": "bun scripts/generate-bot-coordinator.ts --update",
    "generate:skill": "bun scripts/generate-ppm-skill.ts",
    "prepublishOnly": "bun run generate:skill && bun run build:web"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/archiver": "^7.0.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.1",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-precaching": "^7.4.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@codemirror/lang-sql": "^6.10.0",
    "@glideapps/glide-data-grid": "^6.0.3",
    "@inquirer/prompts": "^8.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@skitee3000/bun-pty": "^0.3.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@uiw/react-codemirror": "^4.25.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "diff2html": "^3.4.56",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.8",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "monaco-editor": "0.55.1",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "simple-git": "^3.33.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.3",
    "vite-plugin-monaco-editor": "^1.1.0",
    "web-push": "^3.6.7",
    "zustand": "^5.0.11"
  }
}
