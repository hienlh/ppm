# Copy this file to .env.test and fill with real tokens for integration tests.
# These tokens are used by tests/integration/multi-account-provider.test.ts
# IMPORTANT: .env.test is gitignored. Never commit real tokens.

# OAuth tokens (sk-ant-oat01-*) — required for usage API + SDK tests
# Must be real tokens (>20 chars) — placeholder values are auto-skipped.
TEST_OAUTH_TOKEN_1=REPLACE_WITH_REAL_sk-ant-oat01-token
TEST_OAUTH_TOKEN_2=REPLACE_WITH_REAL_sk-ant-oat01-token
